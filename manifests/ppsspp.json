{
  "manifest_version": 1,
  "id": "ppsspp",
  "name": "PPSSPP",
  "description": "PSP emulator (libretro core)",
  "systems": [
    "psp"
  ],
  "github_repo": "markrpearce96/ppsspp-libretro",
  "executable": "ppsspp_libretro.dylib",
  "install_folder": "libretro",
  "rom_extensions": [
    "iso",
    "cso",
    "chd",
    "pbp",
    "elf",
    "prx"
  ],
  "launch_args": [],
