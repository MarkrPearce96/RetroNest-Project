{
  "manifest_version": 1,
  "id": "pcsx2",
  "name": "PCSX2",
  "description": "PlayStation 2 emulator (libretro core)",
  "systems": [
    "ps2"
  ],
  "github_repo": "markrpearce96/pcsx2-libretro",
